# Frontend environment variables (Vite).
# Copy this file to `.env.local` and fill in your own values.
# Only variables prefixed with VITE_ are exposed to the browser, so never put
# secret/private keys here - use publishable/public keys only.

# Google OAuth client ID (public).
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Stripe publishable key (public, starts with pk_test_ or pk_live_).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
