# ============================================================
# MAGIA - Fichier de configuration d'environnement (Exemple)
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE JAMAIS commiter le fichier .env dans Git !
# ============================================================

# Django
# DJANGO_ENV: 'development' (defaut) ou 'production'. En production, SECRET_KEY
# est OBLIGATOIRE (aucun fallback) et les cookies/SSL securises sont actives.
DJANGO_ENV=development
DEBUG=False
SECRET_KEY=CHANGEZ_EN_PRODUCTION_MINIMUM_50_CARACTERES
# Niveau de log: DEBUG, INFO, WARNING, ERROR (defaut: DEBUG si DEBUG=True sinon INFO)
LOG_LEVEL=INFO

# Base de données (Supabase en production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@db:5432/magia

# Hôtes autorisés (séparés par virgule)
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.railway.app

# CORS (URL de votre frontend Vercel)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Intelligence Artificielle ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Relances CRM automatiques (thread Django, intervalle en secondes)
FOLLOWUP_SCHEDULER_ENABLED=true
FOLLOWUP_SCHEDULER_INTERVAL_SECONDS=3600

# ── Google OAuth2 (pour la connexion Gmail / Email) ──────────
# Type "Application Web" dans Google Cloud Console.
# Redirect URI exacte : http://localhost:8000/api/email-config/oauth2_callback/
# JS origin : http://localhost:5173
# Quotez le secret s'il contient des caractères spéciaux (/).
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email-config/oauth2_callback/

# ── Facebook / Messenger (connexion Pages) ───────────────────
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_VERIFY_TOKEN=magia_fb_webhook_2024

# ── Email SMTP ───────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=MAGIA <your_email@gmail.com>

# ── Stripe (Paiements) ───────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Unipile (LinkedIn / WhatsApp via API) ────────────────────
UNIPILE_API_KEY=your_unipile_api_key
UNIPILE_DSN=https://api45.unipile.com:17515

# ── Daily.co (Vidéo) ─────────────────────────────────────────
DAILY_API_KEY=your_daily_api_key

# ── Apollo.io (recherche de prospects B2B → Email + WhatsApp) ─
# Clé master API : https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=fN0UoMCuFSt609Pe8uEAtg
# Secret vérifié sur le webhook téléphone (query ?token=)
APOLLO_WEBHOOK_SECRET=magia_apollo_webhook_2024
# URL publique atteignable par Apollo (ngrok en local), SANS slash final
# Exemple : https://xxxx.ngrok-free.dev
APOLLO_WEBHOOK_BASE_URL=https://limacine-adrian-sighted.ngrok-free.dev

# ============================================================
# FRONTEND (Vercel) - ces variables sont injectées au build
# ============================================================
VITE_API_URL=https://your-backend.railway.app/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
